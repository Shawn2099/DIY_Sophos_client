# Environment overrides for Sophos WiFi Client.
# Copy to: /etc/default/sophos-wifi-client

# Required secrets for production (recommended)
SOPHOSDIY_USERNAME=your-username
SOPHOSDIY_PASSWORD=your-password

# Optional overrides
# SOPHOSDIY_SSID=YOUR_WIFI_SSID
# SOPHOSDIY_PORTAL_URL=http://YOUR_PORTAL_IP:8090
# SOPHOSDIY_SSID_INTERFACE=wlan0
# SOPHOSDIY_STARTUP_FAST_RETRY_SECONDS=3
# SOPHOSDIY_LOG_LEVEL=INFO
# SOPHOSDIY_LOG_FILE=/var/log/sophos-wifi-client/sophos_wifi.log
# HEALTHCHECK_RESTART_THRESHOLD=6
